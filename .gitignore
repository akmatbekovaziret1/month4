# I asked AI to generate me gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Django stuff
*.log
db.sqlite3
db.sqlite3-journal
media/

# Static files (if collected)
staticfiles/

# Migrations (optional - usually DO NOT ignore)
# */migrations/
# !*/migrations/__init__.py

# PyCharm
.idea/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db

# Coverage reports
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Type checkers
.mypy_cache/
.pyre/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# tox
.tox/
.nox/

# Cache
.cache/

# Local settings
local_settings.py

# Secret key files
secret_key.py